COMPOSE_PROJECT_NAME=shape-vision

BACKEND_CONTAINER_NAME=shape-analyzer-backend
FRONTEND_CONTAINER_NAME=shape-analyzer-frontend

BACKEND_PORT=8000
FRONTEND_PORT=8080

BACKEND_ARTIFACTS_DIR=./backend/artifacts
IMAGE_ANALYZER_MODEL_PATH=/app/artifacts/shape_classifier.pt
IMAGE_ANALYZER_DATA_DIR=/app/hw_light
IMAGE_ANALYZER_DB_URL=sqlite:////app/artifacts/image_analyzer.db
IMAGE_ANALYZER_ALLOW_ORIGINS=http://localhost:8080

VITE_API_BASE_URL=/api/v1
VITE_HEALTH_URL=/health
